# Copy this file to .env and fill in values as they become available.
# Both are optional — the lead capture system works without them (logs
# locally and falls back to a WhatsApp deep link) but won't reach a real
# CRM/email inbox or GA4 until set.

# Where captured leads get POSTed as JSON. Point this at a serverless
# function / webhook that holds the real email + CRM API keys server-side —
# never put those secret keys in a PUBLIC_ variable, they'd ship in the
# public JS bundle.
PUBLIC_LEAD_WEBHOOK_URL=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
PUBLIC_GA4_ID=
