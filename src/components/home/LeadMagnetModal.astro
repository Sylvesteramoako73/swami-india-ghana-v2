---
import { projects, site } from "../../data/site";
---

<div id="lead-magnet-modal" class="hidden fixed inset-0 z-[130] items-center justify-center p-4 sm:p-6">
  <div id="lm-backdrop" class="absolute inset-0 bg-ink/80"></div>

  <div class="relative bg-white text-ink rounded-sm max-w-lg w-full max-h-[92vh] overflow-y-auto">
    <button id="lm-close" aria-label="Close" class="absolute top-4 right-4 z-10 w-9 h-9 rounded-full bg-white flex items-center justify-center text-ink-soft hover:text-ink shadow transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <div class="bg-ink text-white px-8 pt-8 pb-6 sm:px-10 sm:pt-10">
      <p class="text-brand font-semibold uppercase tracking-wide text-xs mb-3">Free For A Limited Time</p>
      <h3 class="text-2xl sm:text-3xl font-bold leading-tight mb-4">Get The Full SIGL Portfolio Guide</h3>
      <ul class="space-y-2 text-sm text-white/80">
        <li class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Pricing &amp; payment plans for every development
        </li>
        <li class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Priority access to new unit launches
        </li>
        <li class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          A free consultation call with our sales team
        </li>
      </ul>

      <div class="flex items-center gap-2 mt-7">
        <span id="lm-dot-1" class="h-1.5 flex-1 rounded-full bg-brand"></span>
        <span id="lm-dot-2" class="h-1.5 flex-1 rounded-full bg-white/20"></span>
      </div>
    </div>

    <div class="p-8 sm:p-10">
      <div id="lm-step-1">
        <p class="font-semibold mb-5">Which development interests you?</p>
        <div class="grid grid-cols-2 gap-3 mb-6">
          {projects.map((p) => (
            <button type="button" data-project={p.name} class="lm-project-btn text-left border-2 border-black/10 hover:border-brand rounded-sm p-3 transition-colors">
              <span class="block font-semibold text-sm">{p.name}</span>
              <span class="block text-xs text-ink-soft mt-0.5">{p.location}</span>
            </button>
          ))}
        </div>
        <button type="button" id="lm-to-step-2" disabled class="btn-primary w-full justify-center opacity-40 cursor-not-allowed">Continue</button>
      </div>

      <div id="lm-step-2" class="hidden">
        <button type="button" id="lm-back" class="text-sm text-ink-soft hover:text-ink mb-5 inline-flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back
        </button>
        <p class="font-semibold mb-1">Almost there</p>
        <p id="lm-selected-project" class="text-sm text-ink-soft mb-5"></p>
        <form id="lm-form" class="space-y-4">
          <input type="text" id="lm-name" required placeholder="Your Name" class="w-full border-2 border-black/10 px-5 py-3.5 focus:outline-none focus:border-brand" />
          <input type="tel" id="lm-phone" required placeholder="Your Phone" class="w-full border-2 border-black/10 px-5 py-3.5 focus:outline-none focus:border-brand" />
          <input type="email" id="lm-email" required placeholder="Your Email" class="w-full border-2 border-black/10 px-5 py-3.5 focus:outline-none focus:border-brand" />
          <button type="submit" class="btn-primary w-full justify-center">Send Me The Guide</button>
        </form>
      </div>

      <div id="lm-step-3" class="hidden text-center py-4">
        <div class="w-16 h-16 rounded-full bg-brand/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h4 class="text-xl font-bold mb-2">You're All Set</h4>
        <p id="lm-success-text" class="text-ink-soft leading-relaxed mb-6">We've sent the portfolio guide to your email, and you're now on our priority launch list. Our sales team will call you shortly to schedule your free consultation.</p>
        <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="btn-primary w-full justify-center">Call Us Now: {site.phone}</a>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ storageKey: "sigl-lead-magnet-dismissed", delayMs: 6000 }}>
  const modal = document.getElementById("lead-magnet-modal");
  const backdrop = document.getElementById("lm-backdrop");
  const closeBtn = document.getElementById("lm-close");
  const step1 = document.getElementById("lm-step-1");
  const step2 = document.getElementById("lm-step-2");
  const step3 = document.getElementById("lm-step-3");
  const dot2 = document.getElementById("lm-dot-2");
  const projectBtns = document.querySelectorAll(".lm-project-btn");
  const toStep2Btn = document.getElementById("lm-to-step-2");
  const backBtn = document.getElementById("lm-back");
  const selectedProjectLabel = document.getElementById("lm-selected-project");
  const form = document.getElementById("lm-form");
  const successText = document.getElementById("lm-success-text");

  let selectedProject = null;

  function open() {
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function close() {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
    document.body.style.overflow = "";
    try {
      localStorage.setItem(storageKey, "1");
    } catch (e) {}
  }

  projectBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      selectedProject = btn.dataset.project;
      projectBtns.forEach((b) => {
        const active = b === btn;
        b.classList.toggle("border-brand", active);
        b.classList.toggle("border-black/10", !active);
      });
      toStep2Btn.disabled = false;
      toStep2Btn.classList.remove("opacity-40", "cursor-not-allowed");
    });
  });

  toStep2Btn?.addEventListener("click", () => {
    if (!selectedProject) return;
    step1.classList.add("hidden");
    step2.classList.remove("hidden");
    selectedProjectLabel.textContent = `For: ${selectedProject}`;
    dot2.classList.remove("bg-white/20");
    dot2.classList.add("bg-brand");
  });

  backBtn?.addEventListener("click", () => {
    step2.classList.add("hidden");
    step1.classList.remove("hidden");
    dot2.classList.remove("bg-brand");
    dot2.classList.add("bg-white/20");
  });

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (selectedProject && successText) {
      successText.textContent = `We've sent the ${selectedProject} pricing and payment plan details to your email, and you're now on our priority launch list. Our sales team will call you shortly to schedule your free consultation.`;
    }
    step2.classList.add("hidden");
    step3.classList.remove("hidden");
  });

  closeBtn?.addEventListener("click", close);
  backdrop?.addEventListener("click", close);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal?.classList.contains("hidden")) close();
  });

  let alreadySeen = false;
  try {
    alreadySeen = localStorage.getItem(storageKey) === "1";
  } catch (e) {}

  if (!alreadySeen) {
    setTimeout(open, delayMs);
  }
</script>
