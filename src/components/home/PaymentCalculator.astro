---
---
<section id="calculator" class="py-24 md:py-32 scroll-mt-24">
  <div class="container-xl">
    <div class="section-head">
      <div>
        <p class="section-tag">Plan Ahead</p>
        <h2 class="section-title">Estimate Your Payment Plan</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-3 bg-surface p-8 md:p-10 rounded-sm space-y-8">
        <div>
          <div class="flex items-center justify-between mb-2">
            <label for="calc-price" class="font-semibold">Target Property Price</label>
            <span class="text-brand font-semibold" id="calc-price-display">GHS 500,000</span>
          </div>
          <input id="calc-price" type="range" min="100000" max="3000000" step="10000" value="500000" class="w-full accent-brand" />
        </div>

        <div>
          <div class="flex items-center justify-between mb-2">
            <label for="calc-down" class="font-semibold">Down Payment</label>
            <span class="text-brand font-semibold" id="calc-down-display">20%</span>
          </div>
          <input id="calc-down" type="range" min="10" max="80" step="5" value="20" class="w-full accent-brand" />
        </div>

        <div>
          <div class="flex items-center justify-between mb-2">
            <label for="calc-months" class="font-semibold">Payment Period</label>
            <span class="text-brand font-semibold" id="calc-months-display">24 months</span>
          </div>
          <input id="calc-months" type="range" min="6" max="60" step="6" value="24" class="w-full accent-brand" />
        </div>
      </div>

      <div class="lg:col-span-2 bg-ink text-white p-8 md:p-10 rounded-sm">
        <p class="text-white/50 uppercase text-xs tracking-wide font-semibold mb-6">Your Estimate</p>
        <div class="space-y-5 mb-8">
          <div class="flex items-center justify-between pb-5 border-b border-white/10">
            <span class="text-white/70">Down Payment</span>
            <span class="font-bold text-lg" id="calc-result-down">GHS 100,000</span>
          </div>
          <div class="flex items-center justify-between pb-5 border-b border-white/10">
            <span class="text-white/70">Remaining Balance</span>
            <span class="font-bold text-lg" id="calc-result-remaining">GHS 400,000</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-white/70">Est. Monthly Installment</span>
            <span class="font-bold text-2xl text-brand" id="calc-result-monthly">GHS 16,667</span>
          </div>
        </div>

        <div id="calc-capture-wrap">
          <p class="text-white/80 text-sm mb-4">Want this payment plan sent to you? We'll send the full breakdown by email and WhatsApp — no obligation.</p>
          <form id="calc-capture-form" class="space-y-3" novalidate>
            <input type="hidden" name="tier" value="warm" />
            <input type="hidden" name="source" value="estimator" />
            <div>
              <label for="calc-name" class="sr-only">Your Name</label>
              <input id="calc-name" name="name" type="text" required placeholder="Your Name" class="w-full bg-white/10 border border-white/15 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-brand" />
            </div>
            <div>
              <label for="calc-email" class="sr-only">Your Email</label>
              <input id="calc-email" name="email" type="email" required placeholder="Your Email" class="w-full bg-white/10 border border-white/15 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-brand" />
            </div>
            <div>
              <label for="calc-whatsapp" class="sr-only">WhatsApp Number</label>
              <input id="calc-whatsapp" name="whatsapp" type="tel" required placeholder="WhatsApp Number" class="w-full bg-white/10 border border-white/15 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-brand" />
            </div>
            <button type="submit" class="btn-primary w-full justify-center">Send Me This Plan</button>
          </form>
          <div id="calc-capture-success" class="hidden text-center py-2" aria-live="polite">
            <p class="font-semibold">Sent!</p>
            <p class="text-white/60 text-sm mt-1">Check your email and WhatsApp for the full breakdown.</p>
          </div>
        </div>

        <a href="/contact-us" class="block text-center text-white/50 text-xs mt-5 hover:text-white transition-colors">Or discuss your plan directly with our sales team &rarr;</a>
        <p class="text-white/40 text-xs leading-relaxed mt-5">
          Illustrative, interest-free estimate for planning purposes only — not a loan offer. Actual pricing and payment plans vary by project and unit type and are confirmed by our sales team.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { trackEstimatorOpened, trackEstimatorCompleted, recordConversion } from "../../lib/intent.js";
  import { submitLead } from "../../lib/leadService.js";
  import { trackEvent } from "../../lib/analytics.js";

  const priceInput = document.getElementById("calc-price") as HTMLInputElement;
  const downInput = document.getElementById("calc-down") as HTMLInputElement;
  const monthsInput = document.getElementById("calc-months") as HTMLInputElement;

  const priceDisplay = document.getElementById("calc-price-display");
  const downDisplay = document.getElementById("calc-down-display");
  const monthsDisplay = document.getElementById("calc-months-display");

  const resultDown = document.getElementById("calc-result-down");
  const resultRemaining = document.getElementById("calc-result-remaining");
  const resultMonthly = document.getElementById("calc-result-monthly");

  const formatCurrency = (value: number) =>
    `GHS ${Math.round(value).toLocaleString("en-US")}`;

  function recalculate() {
    const price = Number(priceInput.value);
    const downPct = Number(downInput.value);
    const months = Number(monthsInput.value);

    const downAmount = price * (downPct / 100);
    const remaining = price - downAmount;
    const monthly = remaining / months;

    priceDisplay!.textContent = formatCurrency(price);
    downDisplay!.textContent = `${downPct}%`;
    monthsDisplay!.textContent = `${months} months`;

    resultDown!.textContent = formatCurrency(downAmount);
    resultRemaining!.textContent = formatCurrency(remaining);
    resultMonthly!.textContent = formatCurrency(monthly);
  }

  let openedTracked = false;
  function trackOpenOnce() {
    if (openedTracked) return;
    openedTracked = true;
    trackEstimatorOpened();
    trackEvent("estimator_opened", {});
  }

  [priceInput, downInput, monthsInput].forEach((input) => {
    input.addEventListener("input", () => {
      recalculate();
      trackOpenOnce();
    });
  });
  recalculate();

  const captureForm = document.getElementById("calc-capture-form") as HTMLFormElement;
  const captureSuccess = document.getElementById("calc-capture-success");

  captureForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(captureForm);
    const payload = Object.fromEntries(formData.entries()) as Record<string, string>;
    payload.price = formatCurrency(Number(priceInput.value));
    payload.monthly = formatCurrency(Number(priceInput.value) * (1 - Number(downInput.value) / 100) / Number(monthsInput.value));

    trackEvent("form_submitted", { tier: "warm", source: "estimator" });
    const submitBtn = captureForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    const result = await submitLead(payload);
    submitBtn.disabled = false;

    if (result.ok) {
      trackEstimatorCompleted();
      recordConversion("warm");
      trackEvent("estimator_completed", {});
      captureForm.classList.add("hidden");
      captureSuccess?.classList.remove("hidden");
    }
  });
</script>
