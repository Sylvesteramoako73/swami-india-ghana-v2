---
import { capabilities } from "../../data/site";
import CapabilityIcon from "../CapabilityIcon.astro";
const featured = capabilities.slice(0, 3);
---
<section class="py-28 md:py-36 bg-surface">
  <div class="container-xl">
    <div class="section-head">
      <div>
        <p class="section-tag">What We Do</p>
        <h2 class="section-title">Our Core Capabilities</h2>
      </div>
      <a href="/about-us" class="btn-primary shrink-0">More About Us</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10">
      {featured.map((s, i) => (
        <div class="bg-white p-12 lg:p-14 relative group hover:shadow-2xl transition-shadow duration-300">
          <span class="absolute top-8 right-10 text-7xl font-heading font-bold text-black/5 group-hover:text-brand/10 transition-colors">0{i + 1}</span>
          <div class="relative z-10 w-24 h-24 rounded-full bg-brand/10 flex items-center justify-center mb-10">
            <CapabilityIcon icon={s.icon} class="w-10 h-10 text-brand" />
          </div>
          <h3 class="text-2xl lg:text-3xl font-bold mb-4">{s.title}</h3>
          <p class="text-ink-soft leading-relaxed">{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
