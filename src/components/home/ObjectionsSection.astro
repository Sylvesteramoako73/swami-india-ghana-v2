---
import { objections } from "../../data/site";
---
<section class="py-28 md:py-36 bg-surface">
  <div class="container-xl">
    <div class="section-head">
      <div>
        <p class="section-tag">Common Concerns, Answered</p>
        <h2 class="section-title">Buying Property In Ghana Comes With Real Questions</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10">
      {objections.map((o) => (
        <div class="bg-white p-10 lg:p-12 rounded-sm">
          <svg class="w-10 h-10 text-brand mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <h3 class="text-xl lg:text-2xl font-bold mb-4">{o.q}</h3>
          <p class="text-ink-soft leading-relaxed">{o.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>
