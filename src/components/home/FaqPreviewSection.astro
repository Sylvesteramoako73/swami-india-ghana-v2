---
import { faqs } from "../../data/site";
const preview = faqs.slice(0, 4);
---
<section class="py-28 md:py-36">
  <div class="container-xl grid grid-cols-1 lg:grid-cols-3 gap-16">
    <div class="lg:col-span-1">
      <p class="section-tag">FAQs</p>
      <h2 class="text-4xl lg:text-5xl font-bold leading-[1.05] mb-6">Questions, Answered</h2>
      <p class="text-lg text-ink-soft leading-relaxed mb-8">
        Can't find what you're looking for? See the full list or reach out to our sales team directly.
      </p>
      <a href="/faq" class="btn-primary">View All FAQs</a>
    </div>

    <div class="lg:col-span-2 space-y-5">
      {preview.map((f, i) => (
        <details class="group bg-surface rounded-sm" open={i === 0}>
          <summary class="flex items-center justify-between gap-4 p-8 text-lg font-semibold cursor-pointer list-none">
            {f.q}
            <svg class="w-6 h-6 text-brand shrink-0 group-open:rotate-45 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          </summary>
          <p class="px-8 pb-8 text-lg text-ink-soft leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
