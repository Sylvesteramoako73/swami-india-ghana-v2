---
interface Post {
  slug: string;
  title: string;
  image: string;
  category: string;
  date: string;
  excerpt?: string;
  body?: string[];
}

interface Props {
  post: Post;
  size?: "lg" | "md";
}

const { post, size = "md" } = Astro.props;

function readingTime(p: Post): number {
  const words = (p.body?.join(" ") ?? p.excerpt ?? "").split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const minutes = readingTime(post);
const isLg = size === "lg";
---

<a
  href={`/blog/${post.slug}`}
  data-category={post.category}
  class:list={["group block", isLg && "grid grid-cols-1 md:grid-cols-2 gap-8 items-center"]}
>
  <div class:list={["relative overflow-hidden rounded-sm", isLg ? "h-72 md:h-full md:min-h-[320px]" : "h-56 mb-6"]}>
    <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />
    <span class="absolute top-4 left-4 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide rounded-full bg-brand text-white">{post.category}</span>
  </div>
  <div>
    <p class="text-xs text-ink-soft uppercase tracking-wide font-semibold mb-3">{post.date} &middot; {minutes} min read</p>
    <h3 class:list={["font-bold leading-snug group-hover:text-brand transition-colors", isLg ? "text-2xl md:text-3xl mb-4" : "text-lg mb-3"]}>{post.title}</h3>
    {(isLg || post.excerpt) && post.excerpt && (
      <p class:list={["text-ink-soft leading-relaxed", isLg ? "text-lg mb-5" : "text-sm mb-4 line-clamp-3"]}>{post.excerpt}</p>
    )}
    <span class="inline-flex items-center gap-1.5 font-semibold text-brand text-sm">
      Read More
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </span>
  </div>
</a>
