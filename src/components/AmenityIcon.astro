---
interface Props {
  label: string;
}
const { label } = Astro.props;
const text = label.toLowerCase();

type IconKey =
  | "shield"
  | "pool"
  | "gym"
  | "sport"
  | "play"
  | "clubhouse"
  | "dining"
  | "parking"
  | "wifi"
  | "water"
  | "elevator"
  | "business"
  | "garden"
  | "infrastructure"
  | "location"
  | "hall"
  | "check";

function matchIcon(): IconKey {
  if (/security|cctv|surveillance/.test(text)) return "shield";
  if (/pool/.test(text)) return "pool";
  if (/gym/.test(text)) return "gym";
  if (/basketball|tennis|court/.test(text)) return "sport";
  if (/play|kids|children/.test(text)) return "play";
  if (/clubhouse/.test(text)) return "clubhouse";
  if (/restaurant|caf[eé]|bar|lounge|spa|dining/.test(text)) return "dining";
  if (/parking/.test(text)) return "parking";
  if (/internet|fibre|fiber|wifi/.test(text)) return "wifi";
  if (/water/.test(text)) return "water";
  if (/elevator/.test(text)) return "elevator";
  if (/business/.test(text)) return "business";
  if (/garden|green/.test(text)) return "garden";
  if (/electrical|infrastructure|road|street/.test(text)) return "infrastructure";
  if (/bank|airport|hospital|commission|headquarters|near|drop-off|square/.test(text)) return "location";
  if (/hall|banquet/.test(text)) return "hall";
  return "check";
}

const icon = matchIcon();

const paths: Record<IconKey, string[]> = {
  shield: ["M12 21c-4-1.5-7-5-7-10V5l7-3 7 3v6c0 5-3 8.5-7 10z", "M9 11.5l2 2 4-4"],
  pool: [
    "M3 13c1.4-1.3 2.8-1.3 4.2 0s2.8 1.3 4.2 0 2.8-1.3 4.2 0 2.8 1.3 4.2 0",
    "M3 17c1.4-1.3 2.8-1.3 4.2 0s2.8 1.3 4.2 0 2.8-1.3 4.2 0 2.8 1.3 4.2 0",
  ],
  gym: ["M4 9v6M2 10v4M20 9v6M22 10v4M7 12h10"],
  sport: ["M12 3a9 9 0 100 18 9 9 0 000-18z", "M3 12h18", "M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"],
  play: ["M12 21a9 9 0 100-18 9 9 0 000 18z", "M9 10h.01M15 10h.01", "M8.5 14.5a4 4 0 007 0"],
  clubhouse: ["M3 21h18", "M5 21V7l7-4 7 4v14", "M9 21v-6h6v6"],
  dining: ["M8 2v6a2 2 0 002 2 2 2 0 002-2V2", "M8 2v20", "M16 2a4 4 0 00-4 4v4h4V2z"],
  parking: ["M5 17h14", "M6 17V9a2 2 0 012-2h8a2 2 0 012 2v8", "M9 7l1-3h4l1 3"],
  wifi: ["M5 12.5a11 11 0 0114 0", "M8 15.7a6.5 6.5 0 018 0", "M12 19a1 1 0 100-2 1 1 0 000 2z"],
  water: ["M12 3s6 6.8 6 11.5a6 6 0 01-12 0C6 9.8 12 3 12 3z"],
  elevator: ["M8 7l4-4 4 4", "M8 17l4 4 4-4", "M12 3v18"],
  business: ["M3 21h18", "M5 21V9a2 2 0 012-2h10a2 2 0 012 2v12", "M9 21v-8h6v8"],
  garden: ["M12 22s8-4.5 8-11.5A8 8 0 004 10.5C4 17.5 12 22 12 22z"],
  infrastructure: ["M13 2L4 14h6l-1 8 9-12h-6l1-8z"],
  location: ["M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z", "M15 11a3 3 0 11-6 0 3 3 0 016 0z"],
  hall: ["M3 21h18", "M5 21V10l7-6 7 6v11", "M9 21v-5h6v5"],
  check: ["M5 13l4 4L19 7"],
};
---
<svg class="w-6 h-6 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
  {paths[icon].map((d) => <path d={d} />)}
</svg>
