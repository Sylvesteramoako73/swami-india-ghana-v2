---
import { site, nav, projects } from "../data/site";
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 bg-transparent transition-colors duration-300">
  <div id="site-header-glow" class="absolute inset-0 -z-10 bg-gradient-to-b from-black/55 via-black/25 to-transparent pointer-events-none transition-opacity duration-300"></div>
  <div class="site-topbar hidden lg:block border-b border-white/20 text-sm">
    <div class="container-xl flex items-center justify-between py-2.5 text-white/80">
      <div class="flex items-center gap-4">
        <a href={site.social.facebook} aria-label="Facebook" class="hover:text-brand transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12a10 10 0 10-11.6 9.87v-6.98H7.9V12h2.5V9.8c0-2.47 1.47-3.84 3.72-3.84 1.08 0 2.2.19 2.2.19v2.42h-1.24c-1.22 0-1.6.76-1.6 1.54V12h2.72l-.44 2.89h-2.28v6.98A10 10 0 0022 12z"/></svg>
        </a>
        <a href={site.social.instagram} aria-label="Instagram" class="hover:text-brand transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2c2.72 0 3.06.01 4.12.06 1.06.05 1.79.22 2.43.47.66.26 1.21.6 1.76 1.15.55.55.9 1.1 1.15 1.76.25.64.42 1.37.47 2.43.05 1.06.06 1.4.06 4.12s-.01 3.06-.06 4.12c-.05 1.06-.22 1.79-.47 2.43a4.9 4.9 0 01-1.15 1.76 4.9 4.9 0 01-1.76 1.15c-.64.25-1.37.42-2.43.47-1.06.05-1.4.06-4.12.06s-3.06-.01-4.12-.06c-1.06-.05-1.79-.22-2.43-.47a4.9 4.9 0 01-1.76-1.15 4.9 4.9 0 01-1.15-1.76c-.25-.64-.42-1.37-.47-2.43C2.01 15.06 2 14.72 2 12s.01-3.06.06-4.12c.05-1.06.22-1.79.47-2.43.26-.66.6-1.21 1.15-1.76a4.9 4.9 0 011.76-1.15c.64-.25 1.37-.42 2.43-.47C9.94 2.01 10.28 2 13 2zm0 1.8c-2.67 0-2.99.01-4.04.06-.97.05-1.5.2-1.85.34-.46.18-.79.4-1.14.75-.35.35-.57.68-.75 1.14-.14.35-.29.88-.34 1.85-.05 1.05-.06 1.37-.06 4.04s.01 2.99.06 4.04c.05.97.2 1.5.34 1.85.18.46.4.79.75 1.14.35.35.68.57 1.14.75.35.14.88.29 1.85.34 1.05.05 1.37.06 4.04.06s2.99-.01 4.04-.06c.97-.05 1.5-.2 1.85-.34.46-.18.79-.4 1.14-.75.35-.35.57-.68.75-1.14.14-.35.29-.88.34-1.85.05-1.05.06-1.37.06-4.04s-.01-2.99-.06-4.04c-.05-.97-.2-1.5-.34-1.85a3.1 3.1 0 00-.75-1.14 3.1 3.1 0 00-1.14-.75c-.35-.14-.88-.29-1.85-.34-1.05-.05-1.37-.06-4.04-.06z"/><path d="M12 7.7a4.3 4.3 0 100 8.6 4.3 4.3 0 000-8.6zm0 7.1a2.8 2.8 0 110-5.6 2.8 2.8 0 010 5.6zM17.65 6.15a1 1 0 100 2 1 1 0 000-2z"/></svg>
        </a>
        <a href={site.social.twitter} aria-label="Twitter" class="hover:text-brand transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 5.9c-.74.33-1.53.55-2.36.65a4.1 4.1 0 001.8-2.27c-.8.47-1.68.82-2.6 1a4.09 4.09 0 00-6.97 3.73A11.6 11.6 0 013 4.9a4.08 4.08 0 001.27 5.46 4.07 4.07 0 01-1.85-.51v.05a4.09 4.09 0 003.28 4.01 4.1 4.1 0 01-1.85.07 4.09 4.09 0 003.82 2.84A8.2 8.2 0 012 18.4a11.57 11.57 0 006.29 1.84c7.55 0 11.68-6.26 11.68-11.68 0-.18 0-.36-.01-.53A8.35 8.35 0 0022 5.9z"/></svg>
        </a>
        <a href={site.social.youtube} aria-label="YouTube" class="hover:text-brand transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2 31.4 31.4 0 000 12a31.4 31.4 0 00.5 5.8 3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1A31.4 31.4 0 0024 12a31.4 31.4 0 00-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
        </a>
      </div>
      <div class="flex items-center gap-6">
        <span class="flex items-center gap-2.5">
          <span class="w-7 h-7 rounded-full bg-brand flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="9" stroke-linecap="round"/></svg>
          </span>
          {site.officeHours}
        </span>
        <a href={`mailto:${site.email}`} class="flex items-center gap-2.5 hover:text-brand transition-colors">
          <span class="w-7 h-7 rounded-full bg-brand flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </span>
          {site.email}
        </a>
        <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="flex items-center gap-2.5 hover:text-brand transition-colors">
          <span class="w-7 h-7 rounded-full bg-brand flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.98.804l.72 3.6a1 1 0 01-.28.94l-1.6 1.6a13.5 13.5 0 006.6 6.6l1.6-1.6a1 1 0 01.94-.28l3.6.72a1 1 0 01.804.98V19a2 2 0 01-2 2h-1C9.163 21 3 14.837 3 7V5z"/></svg>
          </span>
          {site.phone}
        </a>
      </div>
    </div>
  </div>

  <div class="main-nav">
    <div class="container-xl flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src={site.logo} alt={site.name} class="h-10 md:h-12 w-auto" />
      </a>

      <nav class="hidden lg:flex items-center gap-9 ml-auto mr-9">
        {nav.filter((item) => item.href !== "/contact-us").map((item) => (
          item.children ? (
            <div class="relative group">
              <a href={item.href} class="site-nav-link flex items-center gap-1 font-medium text-sm uppercase tracking-wide py-2 text-white hover:text-white/70 transition-colors">
                {item.label}
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute left-0 top-full w-[320px] bg-white shadow-xl border-t-2 border-brand opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 p-1.5">
                {projects.map((p) => (
                  <a href={`/projects/${p.slug}`} class="group/item flex items-center gap-3 p-2 rounded-sm hover:bg-surface transition-colors">
                    <div class="w-11 h-11 rounded-sm overflow-hidden shrink-0">
                      <img src={p.heroImage} alt={p.name} class="w-full h-full object-cover group-hover/item:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${p.theme?.accent ?? "#ca9f45"}`}></span>
                        <p class="font-bold text-xs text-ink group-hover/item:text-brand transition-colors truncate">{p.name}</p>
                      </div>
                      <p class="text-[0.7rem] text-ink-soft mt-0.5 truncate pl-3">{p.location}</p>
                    </div>
                    <span class:list={["shrink-0 px-1.5 py-0.5 text-[0.55rem] font-semibold uppercase tracking-wide rounded-full", p.status === "Completed" ? "bg-ink text-white" : "bg-brand/10 text-brand"]}>{p.status}</span>
                  </a>
                ))}
                <a href="/projects" class="block text-center mt-1 py-2.5 border-t border-black/10 text-sm font-semibold text-brand hover:text-ink transition-colors">View All Projects</a>
              </div>
            </div>
          ) : (
            <a href={item.href} class="site-nav-link font-medium text-sm uppercase tracking-wide text-white hover:text-white/70 transition-colors">{item.label}</a>
          )
        ))}
      </nav>

      <a href="/contact-us" class="site-contact-btn hidden lg:inline-flex items-center gap-2 border-2 border-white/40 text-white font-semibold px-7 py-3 rounded-full hover:bg-brand hover:border-brand hover:text-white transition-colors duration-300 uppercase text-sm tracking-wide shrink-0">
        Contact
      </a>

      <button id="menu-overlay-btn" aria-label="Open menu" class="site-nav-link p-2 text-white hover:text-brand transition-colors shrink-0">
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
</header>

<style>
  header.is-scrolled {
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, white 12%, transparent),
      color-mix(in srgb, var(--color-ink) 20%, transparent) 60%,
      color-mix(in srgb, var(--color-ink) 24%, transparent)
    );
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid color-mix(in srgb, white 22%, transparent);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent);
  }
  header.is-scrolled::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, color-mix(in srgb, white 18%, transparent), transparent 45%);
    pointer-events: none;
  }
  header.is-scrolled .site-nav-link {
    color: var(--color-ink, #1a1a1a);
  }
  header.is-scrolled .site-nav-link:hover {
    color: var(--color-brand, #641e34);
  }
  .site-topbar {
    max-height: 60px;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.25s ease, border-color 0.3s ease;
  }
  header.is-scrolled .site-topbar {
    max-height: 0;
    opacity: 0;
    border-color: transparent;
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const glow = document.getElementById("site-header-glow");

  function onScroll() {
    const scrolled = window.scrollY > 80;
    header?.classList.toggle("is-scrolled", scrolled);
    header?.classList.toggle("bg-transparent", !scrolled);
    glow?.classList.toggle("opacity-0", scrolled);
  }

  document.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
