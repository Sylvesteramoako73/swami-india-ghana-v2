---
import { site } from "../data/site";

interface Props {
  name: string;
  logo?: string;
}
const { name, logo } = Astro.props;

const projectNav = [
  { label: "Overview", href: "#overview" },
  { label: "Gallery", href: "#gallery" },
  { label: "Unit Types", href: "#unit-types" },
  { label: "Amenities", href: "#amenities" },
];
---

<header class="fixed top-0 inset-x-0 z-50 bg-transparent">
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-black/55 via-black/25 to-transparent pointer-events-none"></div>
  <div class="main-nav">
    <div class="container-xl flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-3 shrink-0">
        <span class="hidden sm:flex items-center gap-2 text-white/60 text-xs uppercase tracking-wide border-r border-white/20 pr-3 mr-1 hover:text-brand transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {site.shortName}
        </span>
        {logo ? (
          <img src={logo} alt={name} class="h-10 md:h-12 w-auto" />
        ) : (
          <span class="text-white text-2xl font-bold font-heading">{name}</span>
        )}
      </a>

      <nav class="hidden lg:flex items-center gap-9 ml-auto mr-9">
        {projectNav.map((item) => (
          <a href={item.href} class="font-bold text-sm uppercase tracking-wide text-white hover:text-brand transition-colors">{item.label}</a>
        ))}
      </nav>

      <a href={`/contact-us?project=${encodeURIComponent(name)}`} class="hidden lg:inline-flex items-center gap-2 border-2 border-white/40 text-white font-semibold px-7 py-3 rounded-full hover:bg-brand hover:border-brand transition-colors duration-300 uppercase text-sm tracking-wide shrink-0">
        Enquire Now
      </a>

      <button id="menu-overlay-btn" aria-label="Open menu" class="p-2 text-white hover:text-brand transition-colors shrink-0">
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
</header>
