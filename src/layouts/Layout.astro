---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title,
  description = "Swami India Ghana Ltd — real estate development, civil engineering, and construction across Accra, Ghana.",
  image = site.logo,
  type = "website",
} = Astro.props;

const origin = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, origin);
const pageTitle = `${title} | ${site.shortName}`;

const socialLinks = Object.values(site.social).filter((url) => url !== "#");

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  url: origin.toString(),
  logo: site.logo,
  image: site.logo,
  telephone: site.phone,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address,
    addressLocality: "Accra",
    addressCountry: "GH",
  },
  ...(socialLinks.length > 0 && { sameAs: socialLinks }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={site.favicon} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class="bg-white text-ink">
    <Header />
    <MenuOverlay />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
