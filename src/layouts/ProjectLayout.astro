---
import "../styles/global.css";
import ProjectHeader from "../components/ProjectHeader.astro";
import Footer from "../components/Footer.astro";
import MenuOverlay from "../components/MenuOverlay.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { site } from "../data/site";

interface ProjectData {
  name: string;
  location: string;
  amenities: string[];
  unitTypes: { name: string }[];
}

interface ProjectTheme {
  accent: string;
  onAccent: string;
  cta: string;
  ctaDark: string;
  ctaOn: string;
}

interface Props {
  title: string;
  description?: string;
  logo?: string;
  logoScrolled?: string;
  image?: string;
  project?: ProjectData;
  theme?: ProjectTheme;
}

const {
  title,
  description = "Swami India Ghana Ltd — real estate development, civil engineering, and construction across Accra, Ghana.",
  logo,
  logoScrolled,
  image = site.logo,
  project,
  theme,
} = Astro.props;

const themeStyle = theme
  ? `--project-accent:${theme.accent};--project-on-accent:${theme.onAccent};--project-cta:${theme.cta};--project-cta-dark:${theme.ctaDark};--project-cta-on:${theme.ctaOn};`
  : undefined;

const origin = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, origin);
const pageTitle = `${title} | ${site.shortName}`;

const projectSchema = project && {
  "@context": "https://schema.org",
  "@type": "ApartmentComplex",
  name: project.name,
  description,
  image,
  url: canonicalURL.toString(),
  address: {
    "@type": "PostalAddress",
    addressLocality: project.location,
    addressCountry: "GH",
  },
  numberOfAccommodationUnits: project.unitTypes.length,
  amenityFeature: project.amenities.map((a) => ({
    "@type": "LocationFeatureSpecification",
    name: a,
    value: true,
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={site.favicon} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    {projectSchema && <script type="application/ld+json" set:html={JSON.stringify(projectSchema)} />}
  </head>
  <body class="bg-white text-ink" style={themeStyle}>
    <ProjectHeader name={title} logo={logo} logoScrolled={logoScrolled} />
    <MenuOverlay />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
