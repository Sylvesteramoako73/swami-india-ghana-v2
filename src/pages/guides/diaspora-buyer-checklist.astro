---
import Layout from "../../layouts/Layout.astro";
import { site } from "../../data/site";
---

<Layout title="The Diaspora Buyer's Checklist" description="A free, practical checklist for verifying land title and documentation before buying property in Ghana — built for buyers who can't visit in person.">
  <section class="pt-36 pb-20 md:pt-44 md:pb-28 bg-ink text-white">
    <div class="container-xl">
      <p class="text-brand font-semibold uppercase tracking-wide text-xs mb-4">Free Guide</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight max-w-3xl">The Diaspora Buyer's Guide &amp; Checklist To Buying Property In Ghana Safely</h1>
      <p class="text-white/70 mt-5 max-w-2xl leading-relaxed">
        The documents to request, the questions to ask a seller directly, and a short glossary of the Ghanaian land-law terms you'll encounter — everything referenced in our
        <a href="/blog/land-documentation-title-verification-ghana" class="text-brand hover:text-white transition-colors">full article on land documentation</a>, condensed into one page you can save or print.
      </p>
      <button id="guide-print-btn" type="button" class="btn-primary mt-8 print:hidden">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9V4h12v5M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6v-8z"/></svg>
        Save As PDF / Print
      </button>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container-xl max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Documents To Request Before You Commit</h2>
      <div class="space-y-4 mb-16">
        {[
          { name: "Site plan", detail: "The registered plan showing the exact boundaries and location of the parcel — confirm it matches the land you're actually being shown." },
          { name: "Indenture", detail: "The document recording the transfer of interest in the land. Check the names on it match the person you're dealing with, and trace it back to the prior owner." },
          { name: "Land Title Certificate (where available)", detail: "A stronger, registered form of title obtained through Ghana's Land Title Registration process — ask whether one exists or is in progress." },
          { name: "Lands Commission search report", detail: "Written proof a search was conducted against the specific parcel, not just a verbal assurance that \"it's clean.\"" },
          { name: "Root of title / chain of prior transfers", detail: "Documentation showing how the land moved from its original family, stool, or state allocation into the current seller's hands." },
          { name: "Power of attorney (if someone is signing on the owner's behalf)", detail: "A notarized document, not a verbal claim of authorization." },
          { name: "Building/development permit (for a completed or under-construction unit)", detail: "Confirms the structure itself is authorized, separate from the land title underneath it." },
        ].map((d) => (
          <div class="flex gap-4 bg-surface p-5 rounded-sm">
            <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <p class="font-semibold">{d.name}</p>
              <p class="text-ink-soft text-sm leading-relaxed mt-1">{d.detail}</p>
            </div>
          </div>
        ))}
      </div>

      <h2 class="text-2xl font-bold mb-6">Questions To Ask A Seller Directly</h2>
      <ul class="space-y-3 mb-16 list-none">
        {[
          "Can I see the Lands Commission search report for this specific parcel, not just a general assurance?",
          "Who owned this land before you, and can I see that prior transfer documented?",
          "Is anyone else — family members, a prior buyer, a co-owner — able to claim an interest in this parcel?",
          "If you're not the registered owner, can I see your notarized power of attorney?",
          "Can I engage my own independent lawyer to review these documents before I send any deposit?",
          "What professional bodies is your company registered with, and can I verify that membership independently?",
        ].map((q) => (
          <li class="flex gap-3 bg-white border border-black/10 p-4 rounded-sm">
            <span class="text-brand font-bold shrink-0">?</span>
            <span class="text-ink-soft leading-relaxed">{q}</span>
          </li>
        ))}
      </ul>

      <h2 class="text-2xl font-bold mb-6">A Short Glossary Of Ghanaian Land-Law Terms</h2>
      <dl class="space-y-4 mb-16">
        {[
          { term: "Indenture", def: "A legal document recording the transfer of an interest in land from one party to another." },
          { term: "Land Title Certificate", def: "A registered, searchable record of ownership issued through Ghana's Land Title Registration process — stronger evidence of title than an indenture alone." },
          { term: "Stool / Family land", def: "Land held under customary ownership by a traditional stool (chieftaincy) or an extended family, often the origin point before a parcel is subdivided and sold privately." },
          { term: "Lands Commission", def: "The government body responsible for land administration and registration in Ghana, including conducting title searches." },
          { term: "Root of title", def: "The documented chain of ownership tracing a parcel back to its original, legitimate source — the basis for confirming a seller actually has the right to sell." },
          { term: "Allocation paper / allocation note", def: "An early-stage document from a family or stool indicating land has been set aside for a person, distinct from — and weaker than — a registered indenture or title." },
          { term: "Power of attorney", def: "A notarized legal document authorizing one person to act on behalf of another, such as signing a land sale on the registered owner's behalf." },
        ].map((g) => (
          <div class="border-l-4 border-brand pl-5">
            <dt class="font-semibold">{g.term}</dt>
            <dd class="text-ink-soft text-sm leading-relaxed mt-1">{g.def}</dd>
          </div>
        ))}
      </dl>

      <div class="bg-ink text-white p-8 md:p-10 rounded-sm print:hidden">
        <h3 class="text-xl font-bold mb-3">Ready To Talk To Someone?</h3>
        <p class="text-white/70 mb-6 leading-relaxed">Our sales team can walk through any of this with you directly, on a call or on WhatsApp.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="btn-primary justify-center flex-1">Call {site.phone}</a>
          <a href="/contact-us" class="btn-outline justify-center flex-1 !text-ink !border-black/20 hover:!bg-ink hover:!text-white">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.getElementById("guide-print-btn")?.addEventListener("click", () => window.print());
</script>
