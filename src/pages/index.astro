import AboutSection from "../components/home/AboutSection.astro";
import PortfolioSection from "../components/home/PortfolioSection.astro";
import ObjectionsSection from "../components/home/ObjectionsSection.astro";
import WhyUsSection from "../components/home/WhyUsSection.astro";
import HowItWorksSection from "../components/home/HowItWorksSection.astro";
import ServicesSection from "../components/home/ServicesSection.astro";
import PaymentBand from "../components/home/PaymentBand.astro";
