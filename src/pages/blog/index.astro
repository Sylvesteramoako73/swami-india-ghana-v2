---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import BlogCard from "../../components/BlogCard.astro";
import { blogPosts, blogCategories, site } from "../../data/site";

const sortedPosts = [...blogPosts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const [featured, ...rest] = sortedPosts;
const totalCount = blogPosts.length;
---

<Layout title="Blog" description="News, awards, and construction updates from Swami India Ghana Ltd." image="https://swamiindiaghanaltd.com/wp-content/uploads/2024/06/solaris-1.webp">
  <PageHero title="News & Updates" image="https://swamiindiaghanaltd.com/wp-content/uploads/2024/06/solaris-1.webp" />

  <section class="py-28 md:py-36">
    <div class="container-xl grid grid-cols-1 lg:grid-cols-3 gap-16">
      <div class="lg:col-span-2 space-y-16">
        <div class="pb-14 border-b border-black/10">
          <BlogCard post={featured} size="lg" />
        </div>

        <div id="blog-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-14">
          {rest.map((post) => <BlogCard post={post} />)}
        </div>

        <p id="blog-empty" class="hidden text-ink-soft text-center py-12">No updates in this category yet.</p>
      </div>

      <aside class="space-y-10">
        <div class="bg-surface p-8 rounded-sm">
          <h3 class="font-bold text-lg mb-5">Categories</h3>
          <ul id="blog-categories" class="space-y-1">
            <li>
              <button type="button" data-category="All" class="filter-btn active w-full flex justify-between items-center text-left py-2.5 border-b border-black/5 transition-colors">
                <span>All Updates</span>
                <span class="text-ink-soft text-sm">({totalCount})</span>
              </button>
            </li>
            {blogCategories.map((c) => (
              <li>
                <button type="button" data-category={c.label} class="filter-btn w-full flex justify-between items-center text-left py-2.5 border-b border-black/5 transition-colors">
                  <span>{c.label}</span>
                  <span class="text-ink-soft text-sm">({c.count})</span>
                </button>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-ink text-white p-8 rounded-sm">
          <h3 class="font-bold text-xl mb-3">Interested In A Project?</h3>
          <p class="text-white/70 mb-6 leading-relaxed">Speak with our sales team about availability, pricing, and site visits.</p>
          <ul class="space-y-3 mb-6 text-sm">
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.98.804l.72 3.6a1 1 0 01-.28.94l-1.6 1.6a13.5 13.5 0 006.6 6.6l1.6-1.6a1 1 0 01.94-.28l3.6.72a1 1 0 01.804.98V19a2 2 0 01-2 2h-1C9.163 21 3 14.837 3 7V5z"/></svg>
              <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="hover:text-brand transition-colors">{site.phone}</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href={`mailto:${site.email}`} class="hover:text-brand transition-colors">{site.email}</a>
            </li>
          </ul>
          <a href="/contact-us" class="btn-primary w-full justify-center">Contact Us</a>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .filter-btn.active {
    color: var(--color-brand);
    font-weight: 600;
  }
</style>

<script>
  const buttons = document.querySelectorAll(".filter-btn");
  const grid = document.getElementById("blog-grid");
  const featured = grid ? grid.previousElementSibling : null;
  const cards = document.querySelectorAll("#blog-grid > a");
  const emptyMsg = document.getElementById("blog-empty");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;
      buttons.forEach((b) => b.classList.toggle("active", b === btn));

      let visibleCount = 0;
      cards.forEach((card) => {
        const match = category === "All" || card.dataset.category === category;
        card.classList.toggle("hidden", !match);
        if (match) visibleCount++;
      });

      const featuredLink = featured ? featured.querySelector("a[data-category]") : null;
      const featuredMatch = category === "All" || (featuredLink && featuredLink.dataset.category === category);
      if (featured) featured.classList.toggle("hidden", !featuredMatch);

      emptyMsg?.classList.toggle("hidden", visibleCount > 0 || featuredMatch);
    });
  });
</script>
