---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import PageHero from "../../components/PageHero.astro";
import BrochureModal from "../../components/BrochureModal.astro";
import { projects, blogPosts, site } from "../../data/site";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const relatedPost = blogPosts.find((p) => p.slug.includes(project.slug.split("-")[0]));
const otherProjects = projects.filter((p) => p.slug !== project.slug).slice(0, 3);
---

<ProjectLayout title={project.name} description={project.description} logo={project.logo} image={project.heroImage} project={project}>
  <PageHero title={project.name} image={project.heroImage} />

  <section id="overview" class="py-28 md:py-36 scroll-mt-24">
    <div class="container-xl grid grid-cols-1 lg:grid-cols-3 gap-16">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-4 mb-6">
          <span class:list={["px-4 py-1.5 text-xs font-semibold uppercase tracking-wide rounded-full", project.status === "Completed" ? "bg-brand text-white" : "bg-surface text-ink"]}>{project.status}</span>
          <span class="text-ink-soft">{project.location}</span>
        </div>
        <p class="section-tag">{project.tagline}</p>
        <h2 class="text-4xl md:text-5xl font-bold leading-[1.05] mb-8">{project.name}</h2>
        <p class="text-lg text-ink-soft leading-relaxed">{project.description}</p>

        <div id="gallery" class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-12 scroll-mt-24">
          {project.gallery.map((img) => (
            <img src={img} alt={project.name} class="rounded-sm w-full h-56 object-cover" loading="lazy" decoding="async" />
          ))}
        </div>

        <h3 id="unit-types" class="text-3xl font-bold mt-16 mb-8 scroll-mt-24">Unit Types</h3>
        <div class="space-y-5">
          {project.unitTypes.map((u) => (
            <div class="bg-surface p-8 rounded-sm">
              <h4 class="text-xl font-bold mb-3">{u.name}</h4>
              <div class="flex flex-wrap gap-x-8 gap-y-2 text-ink-soft mb-3">
                {u.plot !== "—" && <span><span class="font-semibold text-ink">Plot:</span> {u.plot}</span>}
                {u.built !== "—" && <span><span class="font-semibold text-ink">Built Area:</span> {u.built}</span>}
              </div>
              <p class="text-ink-soft leading-relaxed">{u.details}</p>
            </div>
          ))}
        </div>

        {project.nearby && (
          <>
            <h3 class="text-3xl font-bold mt-16 mb-8">Location Highlights</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {project.nearby.map((n) => (
                <div class="flex items-center justify-between bg-surface px-6 py-4 rounded-sm">
                  <span class="font-medium">{n.name}</span>
                  <span class="text-brand font-semibold text-sm shrink-0 ml-4">{n.distance}</span>
                </div>
              ))}
            </div>
          </>
        )}
      </div>

      <aside class="lg:col-span-1">
        <div class="bg-ink text-white p-10 rounded-sm sticky top-32">
          <h3 class="text-2xl font-bold mb-6">Interested In {project.name}?</h3>
          <p class="text-white/70 mb-8 leading-relaxed">Speak with our sales team for availability, pricing, and to arrange a site visit.</p>
          <ul class="space-y-4 mb-8 text-sm">
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.98.804l.72 3.6a1 1 0 01-.28.94l-1.6 1.6a13.5 13.5 0 006.6 6.6l1.6-1.6a1 1 0 01.94-.28l3.6.72a1 1 0 01.804.98V19a2 2 0 01-2 2h-1C9.163 21 3 14.837 3 7V5z"/></svg>
              <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="hover:text-brand transition-colors">{site.phone}</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href={`mailto:${site.email}`} class="hover:text-brand transition-colors">{site.email}</a>
            </li>
          </ul>
          <a href={`/contact-us?project=${encodeURIComponent(project.name)}`} class="btn-primary w-full justify-center">Enquire Now</a>
          <BrochureModal projectName={project.name} />
        </div>

        <div id="amenities" class="mt-10 scroll-mt-24">
          <h4 class="font-bold text-lg mb-5">Amenities</h4>
          <ul class="space-y-3">
            {project.amenities.map((a) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-ink-soft">{a}</span>
              </li>
            ))}
          </ul>
        </div>

        {relatedPost && (
          <a href={`/blog/${relatedPost.slug}`} class="group block mt-10 border border-black/10 rounded-sm overflow-hidden hover:shadow-lg transition-shadow">
            <div class="h-40 overflow-hidden">
              <img src={relatedPost.image} alt={relatedPost.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />
            </div>
            <div class="p-6">
              <p class="text-xs text-brand uppercase tracking-wide font-semibold mb-2">Latest Update</p>
              <h4 class="font-bold leading-snug group-hover:text-brand transition-colors">{relatedPost.title}</h4>
            </div>
          </a>
        )}
      </aside>
    </div>
  </section>

  <section class="py-24 bg-surface">
    <div class="container-xl">
      <div class="section-head">
        <div>
          <p class="section-tag">Explore More</p>
          <h2 class="section-title">Other Developments</h2>
        </div>
        <a href="/projects" class="btn-primary shrink-0">All Projects</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {otherProjects.map((p) => (
          <a href={`/projects/${p.slug}`} class="group relative overflow-hidden rounded-sm block h-64">
            <img src={p.heroImage} alt={p.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/90 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="text-white text-lg font-bold">{p.name}</h3>
              <p class="text-white/70 text-sm">{p.location}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</ProjectLayout>
