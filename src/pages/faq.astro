---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { faqs } from "../data/site";
---

<Layout title="FAQ" description="Frequently asked questions about Swami India Ghana Ltd's projects and services." image="https://swamiindiaghanaltd.com/wp-content/uploads/2024/04/paradise-1.webp">
  <PageHero title="Faq" image="https://swamiindiaghanaltd.com/wp-content/uploads/2024/04/paradise-1.webp" />

  <section class="py-28 md:py-36">
    <div class="container-xl grid grid-cols-1 lg:grid-cols-3 gap-16">
      <div class="lg:col-span-1">
        <p class="section-tag">Got Questions?</p>
        <h2 class="text-4xl lg:text-5xl font-bold leading-[1.05] mb-6">Frequently Asked Questions</h2>
        <p class="text-lg text-ink-soft leading-relaxed mb-8">
          Can't find the answer you're looking for? Reach out to our sales team directly and we'll get back to you.
        </p>
        <a href="/contact-us" class="btn-primary">Contact Us</a>
      </div>

      <div class="lg:col-span-2 space-y-5">
        {faqs.map((f, i) => (
          <details class="group bg-surface rounded-sm" open={i === 0}>
            <summary class="flex items-center justify-between gap-4 p-8 text-lg font-semibold cursor-pointer list-none">
              {f.q}
              <svg class="w-6 h-6 text-brand shrink-0 group-open:rotate-45 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <p class="px-8 pb-8 text-lg text-ink-soft leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
